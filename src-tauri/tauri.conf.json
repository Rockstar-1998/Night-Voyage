{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Night Voyage",
  "version": "0.1.0",
  "identifier": "com.nightvoyage.app",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Night Voyage",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "center": true,
        "decorations": false,
        "shadow": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}